# Application
GRNA_APP_NAME=bosgenesis-release-note-agent
GRNA_ENVIRONMENT=local
GRNA_LOG_LEVEL=INFO
GRNA_LOG_FORMAT=json

# Runtime modes
GRNA_ENABLE_REST_API=true
GRNA_ENABLE_MCP_SERVER=true
GRNA_ENABLE_CLI=true

# Network
GRNA_API_HOST=0.0.0.0
GRNA_API_PORT=8080
GRNA_MCP_HOST=0.0.0.0
GRNA_MCP_PORT=8090
GRNA_MCP_ALLOWED_HOSTS=localhost,127.0.0.1,release-note-agent.bosgenesis.local,bosgenesis-release-note-agent-mcp,bosgenesis-release-note-agent-mcp.bosgenesis.svc,bosgenesis-release-note-agent-mcp.bosgenesis.svc.cluster.local

# Storage
GRNA_WORKSPACE_ROOT=data/workspaces
GRNA_ARTIFACT_ROOT=data/artifacts
GRNA_JOB_ROOT=data/jobs
GRNA_LOG_ROOT=data/logs

# Repository safety limits
GRNA_MAX_REPO_SIZE_MB=500
GRNA_MAX_FILE_SIZE_MB=10
GRNA_CLONE_TIMEOUT_SECONDS=120
GRNA_ANALYSIS_TIMEOUT_SECONDS=600

# Optional integrations
GRNA_DATABASE_URL=
GRNA_REDIS_URL=
GRNA_ENABLE_OTEL=false
GRNA_ENABLE_LANGFUSE=false
LANGFUSE_HOST=http://langfuse-web.bosgenesis.svc.cluster.local:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
OTEL_EXPORTER_OTLP_ENDPOINT=http://signoz-otel-collector.signoz.svc.cluster.local:4317
OBSERVABILITY_AUDIT_ENABLED=true
OBSERVABILITY_PHASE_METRICS_ENABLED=true
OBSERVABILITY_WARNING_TAXONOMY_ENABLED=true
GRNA_ENABLE_LLM_SUMMARY=false
GRNA_ENABLE_PDF_RENDERING=true
